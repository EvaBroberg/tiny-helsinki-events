{
  "name": "tiny-helsinki-events",
  "version": "0.1.0",
  "description": "A cute desktop app showing fresh, temporary kid-friendly events around Helsinki, Espoo, Vantaa and Sipoo.",
  "author": "Tiny Helsinki Events",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "scrape": "tsx src/main/scrapers/cli.ts",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || echo \"electron-rebuild skipped (native module will rebuild on first electron run)\""
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
